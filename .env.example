# Copie este arquivo para ".env" e preencha com as credenciais que a Clinicorp te enviar.
# (O suporte da Clinicorp libera o acesso de API por assinante.)

# Base da API. Confirme o valor exato no Swagger: https://sistema.clinicorp.com/api-docs/
CLINICORP_BASE_URL=https://sistema.clinicorp.com/api

# Identificador da sua assinatura/clinica (tenant)
CLINICORP_SUBSCRIBER=seu_subscriber_aqui

# Token / chave de API fornecida pela Clinicorp
CLINICORP_API_KEY=seu_token_aqui

# Modo de autenticacao: "headers" (subscriber + x-api-key) ou "basic" (usuario:senha)
# Confirme qual a Clinicorp usa para a sua conta.
CLINICORP_AUTH_MODE=headers

# Usado apenas se CLINICORP_AUTH_MODE=basic
CLINICORP_USERNAME=
CLINICORP_PASSWORD=
